---
// src/components/Header.astro
const navLinks = [
  { name: "Home", href: "/Ammo" },
  { name: "About", href: "  /Ammo" },
  { name: "Projects", href: "/Ammo" },
  { name: "Contact", href: "/Ammo" },
];
---

<header class="p-4 sticky top-0 z-50 mix-blend-difference tracking-wide">
  <nav class="flex justify-between">
    <img class="w-30 h-6.5" src="../../public/ammo_logo-2.webp" />
    <ul class="flex gap-12 text-md font-poppins items-center">
      {
        navLinks.map((link) => (
          <li class="hidden sm:block ">
            <a href={link.href}>{link.name}</a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
