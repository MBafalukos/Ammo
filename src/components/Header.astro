---
// src/components/Header.astro
const basePath = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
const navLinks = [
  { name: "Home", href: `${basePath}/` },
  { name: "About", href: `${basePath}/` },
  { name: "Projects", href: `${basePath}/` },
  { name: "Contact", href: `${basePath}/` },
];
---

<header class="p-4 sticky top-0 z-50 mix-blend-difference tracking-wide">
  <nav class="flex justify-between">
    <img class="w-30 h-6.5" src={`${basePath}/ammo_logo-2.webp`} />
    <ul class="flex gap-12 text-md font-poppins items-center">
      {
        navLinks.map((link) => (
          <li class="hidden sm:block ">
            <a href={link.href}>{link.name}</a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
